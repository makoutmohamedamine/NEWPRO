# ── Django ───────────────────────────────────────────────────────────────────────
SECRET_KEY=une-cle-secrete-longue-ici-changez-moi
DEBUG=True

# ── Base de données ───────────────────────────────────────────────────────────────
# SQLite (développement) — ne pas remplir les champs DB_* ci-dessous
# Pour PostgreSQL : décommenter et remplir
SECRET_KEY=cle-secrete-longue-ici
DB_NAME=cv_db
DB_USER=postgres
DB_PASSWORD=123456789
DB_HOST=localhost
DB_PORT=5433
# ── Microsoft Azure / Outlook Office 365 ─────────────────────────────────────────
# Étapes pour obtenir ces valeurs :
# 1. Aller sur https://portal.azure.com → Azure Active Directory → App Registrations
# 2. Créer une nouvelle application (ou utiliser une existante)
# 3. Dans "Certificates & Secrets" → créer un Client Secret → copier la valeur
# 4. Dans "API Permissions" → ajouter : Mail.Read, User.Read.All (Application type)
# 5. Accorder le consentement administrateur (Admin Consent)

AZURE_TENANT_ID=votre-tenant-id-ici
AZURE_CLIENT_ID=votre-client-id-ici
AZURE_CLIENT_SECRET=votre-client-secret-ici

# Boite mail Outlook à surveiller (adresse email complète)
OUTLOOK_MAILBOX=recrutement@votre-entreprise.com

# Nombre maximum d'emails à traiter par cycle de synchro
OUTLOOK_MAX_MESSAGES=50

# ── Gmail API (OAuth2) ────────────────────────────────────────────────────────
# Fichiers générés par Google Cloud Console
# Autorisation initiale : python manage.py gmail_auth
GMAIL_CLIENT_SECRET_FILE=C:\Users\LENOVO\Desktop\newpro\backend\client_secret.json
GMAIL_TOKEN_FILE=C:\Users\LENOVO\Desktop\newpro\backend\token.json
GMAIL_MAX_MESSAGES=50

# ── Anthropic / Claude AI ─────────────────────────────────────────────────────
# Obtenir la clé sur https://console.anthropic.com/
ANTHROPIC_API_KEY=votre-cle-api-anthropic-ici
