# Copier vers /var/www/newpro/backend/.env sur le serveur
# Ne jamais committer le fichier .env reel

# --- Django (obligatoire) ---
SECRET_KEY=changez-moi-avec-python-c secrets.token_urlsafe(50)
DEBUG=False
ALLOWED_HOSTS=votre-domaine.com,www.votre-domaine.com,IP_DU_SERVEUR
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://votre-domaine.com

# --- PostgreSQL (obligatoire) ---
DB_NAME=newpro
DB_USER=newpro
DB_PASSWORD=mot_de_passe_fort
DB_HOST=127.0.0.1
DB_PORT=5432

# --- IA Groq (optionnel, pour analyse IA) ---
AI_PROVIDER=grok
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# --- Gmail (optionnel) ---
GMAIL_CLIENT_SECRET_FILE=/var/www/newpro/backend/client_secret.json
GMAIL_TOKEN_FILE=/var/www/newpro/backend/token.json
GMAIL_MAX_MESSAGES=50
DISABLE_AUTO_SYNC=false
AUTO_SYNC_INTERVAL_MINUTES=15

# --- Outlook / Azure (optionnel) ---
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
OUTLOOK_MAILBOX=
OUTLOOK_MAX_MESSAGES=50
